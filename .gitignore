# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/
website/node_modules/

# Build output
frontend/dist/
frontend/.vite/
website/dist/
website/dist-ssr/

# Environment — never commit real secrets
backend/.env
frontend/.env
frontend/.env.local

# SQLite database — data lives on the server, not in git
backend/edgelog.db
backend/edgelog.db-shm
backend/edgelog.db-wal

# Uploaded screenshots — tracked via .gitkeep placeholder, not actual files
backend/uploads/*
!backend/uploads/.gitkeep

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor
.vscode/*
!.vscode/extensions.json
.idea

# Misc
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local

# Vercel
.vercel
