# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# Deployed frontend URL — set this to your Vercel URL (no trailing slash)
# Example: https://edgelog.vercel.app
FRONTEND_URL=http://localhost:5173

# ── Database (Railway persistent storage) ────────────────────────────────────
# On Railway: add a Volume mounted at /data, then set this variable.
# Locally: leave unset — defaults to ./edgelog.db
# DB_PATH=/data/edgelog.db

# ── Stripe (optional — payments disabled if not set) ─────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_TRADER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...

# ── Plaid (optional — brokerage sync disabled if not set) ────────────────────
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
