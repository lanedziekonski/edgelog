# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Render provides this automatically when you attach a Postgres database.
# For local dev: install Postgres locally or use a free Neon/Supabase instance.
DATABASE_URL=postgresql://user:password@host:5432/edgelog

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Deployed frontend URL — set this to your Vercel URL (no trailing slash)
FRONTEND_URL=http://localhost:5173

# ── Stripe (optional — payments disabled if not set) ─────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_TRADER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...

# ── Plaid (optional — brokerage sync disabled if not set) ────────────────────
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
